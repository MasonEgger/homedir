#!/usr/bin/env -S uv run --script
# ABOUTME: Install or update Claude Code plugins from multiple marketplaces.
# Ensures marketplaces are configured, then installs/updates each plugin.

# /// script
# requires-python = ">=3.12"
# dependencies = []
# ///

"""Install or update Claude Code plugins from multiple marketplaces."""

import re
import subprocess

FRESH_INSTALL_RE = re.compile(r"already installed", re.IGNORECASE)
# `claude plugin list` renders each plugin as "❯ name@marketplace" then "Version: X".
LIST_NAME_RE = re.compile(r"❯\s+(\S+)")
LIST_VERSION_RE = re.compile(r"Version:\s*(.+)")

MARKETPLACES: list[tuple[str, str]] = [
    # (name, github_repo)
    ("anthropic-agent-skills", "anthropics/skills"),
    ("claude-plugins-official", "anthropics/claude-plugins-official"),
    ("mmegger-plugins", "MasonEgger/claude-code-plugin"),
    ("mmegger-private-plugins", "MasonEgger/claude-code-plugin-private"),
    ("obsidian-skills", "kepano/obsidian-skills"),
    ("slidev-plugins", "slidevjs/slidev"),
    ("temporal-marketplace", "temporalio/claude-temporal-plugin"),
]

PLUGINS: list[tuple[str, str]] = [
    # (plugin_name, marketplace)
    ("asana", "claude-plugins-official"),
    ("discord", "claude-plugins-official"),
    ("frontend-design", "claude-plugins-official"),
    ("playground", "claude-plugins-official"),
    ("playwright", "claude-plugins-official"),
    ("plugin-dev", "claude-plugins-official"),
    ("skill-creator", "claude-plugins-official"),
    ("slack", "claude-plugins-official"),
    ("telegram", "claude-plugins-official"),
    ("bpe", "mmegger-plugins"),
    ("python", "mmegger-plugins"),
    ("content-design", "mmegger-private-plugins"),
    ("health", "mmegger-private-plugins"),
    ("indie", "mmegger-private-plugins"),
    ("productivity", "mmegger-private-plugins"),
    ("example-skills", "anthropic-agent-skills"),
    ("obsidian", "obsidian-skills"),
    ("slidev", "slidev-plugins"),
    ("temporal", "temporal-marketplace"),
]


def run_claude(args: list[str]) -> subprocess.CompletedProcess[str]:
    """Run a claude CLI command and return the result."""
    return subprocess.run(
        ["claude", *args],
        capture_output=True,
        text=True,
    )


def ensure_marketplaces() -> bool:
    """Ensure all required marketplaces are configured. Return False on failure."""
    ok = True
    for name, repo in MARKETPLACES:
        print(f"Ensuring marketplace {name}...", end=" ", flush=True)
        result = run_claude(["plugin", "marketplace", "add", repo])
        if result.returncode != 0:
            print(f"FAILED: {result.stderr.strip() or result.stdout.strip()}")
            ok = False
        else:
            print("ok")
    return ok


def installed_versions() -> dict[str, str]:
    """Map qualified plugin name to its currently installed version."""
    result = run_claude(["plugin", "list"])
    versions: dict[str, str] = {}
    current: str | None = None
    for line in f"{result.stdout}\n{result.stderr}".splitlines():
        name_match = LIST_NAME_RE.search(line)
        if name_match:
            current = name_match.group(1)
            continue
        version_match = LIST_VERSION_RE.search(line)
        if version_match and current:
            versions[current] = version_match.group(1).strip()
            current = None
    return versions


def show_version(version: str | None) -> str:
    """Render a version for display, hiding the marketplace's `unknown` sentinel."""
    return f" {version}" if version and version != "unknown" else ""


def sync_plugins() -> None:
    """Install/update each plugin, then report version changes.

    The verdict comes from comparing the installed version before and after,
    not from the `claude plugin update` message. That message is unreliable:
    plugins the marketplace leaves unversioned (Version: unknown) are re-pulled
    on every run and always print "refreshed from source", which would otherwise
    read as a spurious update on every invocation.
    """
    before = installed_versions()
    failures: dict[str, str] = {}
    freshly: set[str] = set()

    print("Syncing plugins", end="", flush=True)
    for plugin, marketplace in PLUGINS:
        qualified = f"{plugin}@{marketplace}"
        # install is idempotent — succeeds even if already installed
        install_result = run_claude(["plugin", "install", qualified])
        if install_result.returncode != 0:
            failures[qualified] = (
                install_result.stderr.strip() or install_result.stdout.strip()
            )
            print("x", end="", flush=True)
            continue
        install_output = f"{install_result.stdout}\n{install_result.stderr}"
        if not FRESH_INSTALL_RE.search(install_output):
            freshly.add(qualified)
        # update to latest version
        update_result = run_claude(["plugin", "update", qualified])
        if update_result.returncode != 0:
            failures[qualified] = (
                "update failed: "
                f"{update_result.stderr.strip() or update_result.stdout.strip()}"
            )
            print("x", end="", flush=True)
            continue
        print(".", end="", flush=True)
    print()

    after = installed_versions()
    for plugin, marketplace in PLUGINS:
        qualified = f"{plugin}@{marketplace}"
        label = f"{plugin} ({marketplace})"
        old, new = before.get(qualified), after.get(qualified)
        if qualified in failures:
            print(f"❌ {label}: {failures[qualified]}")
        elif qualified in freshly:
            print(f"🆕 {label}: installed{show_version(new)}")
        elif old and new and old != new:
            print(f"🚧 {label}: updated {old} -> {new}")
        elif new and new != "unknown":
            print(f"✓ {label}: up to date {new}")
        else:
            print(f"🔄 {label}: refreshed from source (unversioned)")


def main() -> None:
    """Entry point."""
    if not ensure_marketplaces():
        print(
            "\nMarketplace setup had errors. Continuing with available marketplaces...\n"
        )

    sync_plugins()
    print("\nRun /reload-plugins in Claude Code to activate changes.")


if __name__ == "__main__":
    main()
