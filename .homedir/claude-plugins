#!/usr/bin/env -S uv run --script
# ABOUTME: Install or update Claude Code plugins from multiple marketplaces.
# Ensures marketplaces are configured, then installs/updates each plugin.

# /// script
# requires-python = ">=3.12"
# dependencies = []
# ///

"""Install or update Claude Code plugins from multiple marketplaces."""

import re
import subprocess
import sys

VERSION_RE = re.compile(r"\(([^()]*\d[^()]*)\)")
ALREADY_LATEST_RE = re.compile(r"already at the latest version", re.IGNORECASE)
FRESH_INSTALL_RE = re.compile(r"already installed", re.IGNORECASE)

MARKETPLACES: list[tuple[str, str]] = [
    # (name, github_repo)
    ("anthropic-agent-skills", "anthropics/skills"),
    ("claude-plugins-official", "anthropics/claude-plugins-official"),
    ("mmegger-plugins", "MasonEgger/claude-code-plugin"),
    ("mmegger-private-plugins", "MasonEgger/claude-code-plugin-private"),
    ("obsidian-skills", "kepano/obsidian-skills"),
    ("slidev-plugins", "slidevjs/slidev"),
    ("temporal-marketplace", "temporalio/claude-temporal-plugin"),
]

PLUGINS: list[tuple[str, str]] = [
    # (plugin_name, marketplace)
    ("asana", "claude-plugins-official"),
    ("discord", "claude-plugins-official"),
    ("frontend-design", "claude-plugins-official"),
    ("playground", "claude-plugins-official"),
    ("playwright", "claude-plugins-official"),
    ("plugin-dev", "claude-plugins-official"),
    ("skill-creator", "claude-plugins-official"),
    ("slack", "claude-plugins-official"),
    ("telegram", "claude-plugins-official"),
    ("bpe", "mmegger-plugins"),
    ("python", "mmegger-plugins"),
    ("content-design", "mmegger-private-plugins"),
    ("health", "mmegger-private-plugins"),
    ("indie", "mmegger-private-plugins"),
    ("productivity", "mmegger-private-plugins"),
    ("example-skills", "anthropic-agent-skills"),
    ("obsidian", "obsidian-skills"),
    ("slidev", "slidev-plugins"),
    ("temporal", "temporal-marketplace"),
]


def run_claude(args: list[str]) -> subprocess.CompletedProcess[str]:
    """Run a claude CLI command and return the result."""
    return subprocess.run(
        ["claude", *args],
        capture_output=True,
        text=True,
    )


def ensure_marketplaces() -> bool:
    """Ensure all required marketplaces are configured. Return False on failure."""
    ok = True
    for name, repo in MARKETPLACES:
        print(f"Ensuring marketplace {name}...", end=" ", flush=True)
        result = run_claude(["plugin", "marketplace", "add", repo])
        if result.returncode != 0:
            print(f"FAILED: {result.stderr.strip() or result.stdout.strip()}")
            ok = False
        else:
            print("ok")
    return ok


def extract_version(text: str) -> str | None:
    """Pull a version-like token out of CLI output, if present."""
    match = VERSION_RE.search(text)
    return match.group(1) if match else None


def sync_plugins() -> None:
    """Install or update each plugin."""
    for plugin, marketplace in PLUGINS:
        qualified = f"{plugin}@{marketplace}"
        print(f"Syncing {plugin} ({marketplace})...", end=" ", flush=True)
        # install is idempotent — succeeds even if already installed
        install_result = run_claude(["plugin", "install", qualified])
        if install_result.returncode != 0:
            print(f"FAILED: {install_result.stderr.strip() or install_result.stdout.strip()}")
            continue
        install_output = f"{install_result.stdout}\n{install_result.stderr}"
        freshly_installed = not FRESH_INSTALL_RE.search(install_output)
        # update to latest version
        update_result = run_claude(["plugin", "update", qualified])
        if update_result.returncode != 0:
            print(
                f"installed, but update FAILED: "
                f"{update_result.stderr.strip() or update_result.stdout.strip()}"
            )
            continue
        update_output = f"{update_result.stdout}\n{update_result.stderr}"
        version = extract_version(update_output) or extract_version(install_output)
        version_suffix = f" {version}" if version else ""
        if freshly_installed:
            print(f"🆕 installed{version_suffix}")
        elif ALREADY_LATEST_RE.search(update_output):
            print(f"✓ up to date{version_suffix}")
        else:
            print(f"🚧 updated{version_suffix}")


def main() -> None:
    """Entry point."""
    if not ensure_marketplaces():
        print("\nMarketplace setup had errors. Continuing with available marketplaces...\n")

    sync_plugins()
    print("\nRun /reload-plugins in Claude Code to activate changes.")


if __name__ == "__main__":
    main()
