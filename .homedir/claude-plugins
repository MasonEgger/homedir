#!/usr/bin/env -S uv run --script
# ABOUTME: Install or update Claude Code plugins from the official marketplace.
# Loops through a defined list, installing missing plugins and updating existing ones.

# /// script
# requires-python = ">=3.12"
# dependencies = []
# ///

"""Install or update Claude Code plugins from the official marketplace."""

import json
import subprocess
import sys
from pathlib import Path

OFFICIAL_MARKETPLACE = "claude-plugins-official"
PERSONAL_MARKETPLACE = "mason-claude-plugins"
PERSONAL_MARKETPLACE_REPO = "MasonEgger/claude-code-plugin"

OFFICIAL_PLUGINS = [
    "asana",
    "discord",
    "frontend-design",
    "playground",
    "playwright",
    "plugin-dev",
    "skill-creator",
    "slack",
    "telegram",
]

PERSONAL_PLUGINS = [
    "bpe",
    "writing",
    "productivity",
]


def get_installed_plugins() -> set[str]:
    """Return set of plugin names currently installed."""
    installed_file = Path.home() / ".claude" / "plugins" / "installed_plugins.json"
    if not installed_file.exists():
        return set()
    data = json.loads(installed_file.read_text())
    # Keys are "plugin-name@marketplace"
    return {key.split("@")[0] for key in data.get("plugins", {})}


def run_claude(args: list[str]) -> bool:
    """Run a claude CLI command, return True on success."""
    result = subprocess.run(
        ["claude", *args],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print(f"  FAILED: {result.stderr.strip() or result.stdout.strip()}")
        return False
    return True


def ensure_personal_marketplace() -> None:
    """Register the personal marketplace if not already present."""
    print(f"Registering personal marketplace ({PERSONAL_MARKETPLACE_REPO})...", end=" ")
    if run_claude(["plugin", "marketplace", "add", PERSONAL_MARKETPLACE_REPO]):
        print("done")


def sync_plugins(plugins: list[str], marketplace: str) -> None:
    """Install or update a list of plugins from a marketplace."""
    installed = get_installed_plugins()
    for plugin in plugins:
        qualified = f"{plugin}@{marketplace}"
        if plugin in installed:
            print(f"Updating {plugin}...", end=" ")
            if run_claude(["plugin", "update", qualified]):
                print("done")
        else:
            print(f"Installing {plugin}...", end=" ")
            if run_claude(["plugin", "install", qualified]):
                print("done")


def main() -> None:
    """Entry point."""
    ensure_personal_marketplace()
    print("\n--- Official plugins ---")
    sync_plugins(OFFICIAL_PLUGINS, OFFICIAL_MARKETPLACE)
    print("\n--- Personal plugins ---")
    sync_plugins(PERSONAL_PLUGINS, PERSONAL_MARKETPLACE)
    print("\nRun /reload-plugins in Claude Code to activate changes.")


if __name__ == "__main__":
    main()
