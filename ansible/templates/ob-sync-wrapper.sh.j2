#!/usr/bin/env bash
# ABOUTME: Wrapper that sources nvm and runs `ob sync --continuous` for a vault.
# Used by the ob-sync.service systemd unit. Generated by ansible.
set -e
export NVM_DIR="$HOME/.nvm"
# shellcheck source=/dev/null
. "$NVM_DIR/nvm.sh"
nvm use --lts >/dev/null
exec ob sync --path "$HOME/{{ obsidian_vault_name }}" --continuous
