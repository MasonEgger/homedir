[user]
        name = Mason Egger
        email = mason@masonegger.com
{% if ssh_signing_key is defined and ssh_signing_key != '' %}
        signingkey = {{ ssh_signing_key }}
{% elif gpg_signing_key is defined and gpg_signing_key != '' %}
        signingkey = {{ gpg_signing_key }}
{% else %}
        # signingkey not configured - no SSH or GPG key found
{% endif %}
[commit]
{% if (ssh_signing_key is defined and ssh_signing_key != '') or (gpg_signing_key is defined and gpg_signing_key != '') %}
        gpgsign = true
{% else %}
        gpgsign = false
{% endif %}
{% if ssh_signing_key is defined and ssh_signing_key != '' %}
[gpg]
        format = ssh
{% endif %}
[pull]
        rebase = true
[init]
        defaultBranch = main
[core]
        hooksPath = ~/.config/git/hooks
[alias]
        status = status -u
